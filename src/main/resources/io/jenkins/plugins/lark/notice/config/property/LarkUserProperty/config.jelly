<?jelly escape-by-default='true'?>
<j:jelly xmlns:j="jelly:core" xmlns:f="/lib/form">
    <f:entry title="${%user.mobile}">
        <f:textbox field="mobile" placeholder="${%user.mobile.placeholder}"/>
    </f:entry>
    <f:entry title="${%user.openid}" description="${%user.openid.description}">
        <f:textbox field="openId" placeholder="${%user.openid.placeholder}"/>
    </f:entry>
</j:jelly>
